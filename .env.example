# Required: password for the protected admin/content routes.
PAGE_ACCESS_PASSWORD=change-this-before-deploying

# Optional: local SQLite database file. Use a persistent disk path in production.
SQLITE_DATABASE_PATH=./data/content.sqlite

# Optional: uploaded image storage. Mount this directory as persistent storage in production.
UPLOAD_DIR=./public/images/uploads
UPLOAD_PUBLIC_PATH=/images/uploads
